{
  "expo": {
    "name": "うちのモン",
    "slug": "uchinomon",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "uchinomon",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.starvingeffort.uchinomon",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ja",
        "CFBundleLocalizations": [
          "ja"
        ],
        "CFBundleAllowMixedLocalizations": true,
        "NSCameraUsageDescription": "おえかきを さつえいして、たんまつの なかだけで うごく モンスターに へんしんさせます。しゃしんは サーバーに おくられず、たんまつから そとに でません。",
        "NSPhotoLibraryUsageDescription": "えらんだ おえかきの しゃしんを よみこみます。しゃしんは サーバーに おくられず、たんまつの なかだけで しょりされます。",
        "NSFaceIDUsageDescription": "おうちのひと だけが かいいん とうろくや こうにゅうを できるように、Face ID で ほごしゃ かくにんを します。",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": [
              "E174.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          }
        ],
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FDF6E9",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "app.starvingeffort.uchinomon",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FDF6E9",
          "dark": {
            "backgroundColor": "#FDF6E9"
          },
          "android": {
            "backgroundColor": "#FDF6E9"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "おえかきを さつえいして、たんまつの なかだけで うごく モンスターに へんしんさせます。"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "えらんだ おえかきの しゃしんを よみこみます。たんまつの なかだけで しょりされます。"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "おうちのひと だけが かいいん とうろくや こうにゅうを できるように、Face ID で ほごしゃ かくにんを します。"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {}
    }
  }
}